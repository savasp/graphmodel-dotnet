root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4

# File headers
file_header_template = Copyright CVOYA LLC. Licensed under the Apache License, Version 2.0.\nSee LICENSE in the project root for full license terms.
dotnet_diagnostic.IDE0073.severity = error

# Retain the existing quality baseline while making the complete .NET security
# analyzer set fail closed.
dotnet_analyzer_diagnostic.category-Security.severity = error

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_style_namespace_declarations = file_scoped:silent
csharp_style_prefer_primary_constructors = true:silent
csharp_style_prefer_collection_expression = true:silent
dotnet_style_qualification_for_event = false:silent
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_property = false:silent

# Tutorial domain models intentionally stay in the global namespace beside top-level programs so
# each example can focus on graph concepts without namespace ceremony. Friend is also part of the
# model vocabulary in those self-contained samples.
[examples/**/DomainModel.cs]
dotnet_diagnostic.CA1050.severity = none
dotnet_diagnostic.CA1716.severity = none

# The non-generic graph-queryable interfaces are marker bases for runtime type inspection. Their
# generic counterparts provide the strongly typed enumeration surface.
[src/Graph/GraphQueryable/IGraph*Queryable.cs]
dotnet_diagnostic.CA1010.severity = none

# These established public names are serialized or consumer-facing contracts; renaming them would
# be a source-breaking remediation for naming-only diagnostics.
[src/Graph/IGraphPath.cs]
dotnet_diagnostic.CA1716.severity = none

[src/Graph/Querying/Model/TerminalOperation.cs]
dotnet_diagnostic.CA1720.severity = none

[src/Graph.Serialization/RuntimeRepresentation/{EntityCollection,SimpleCollection}.cs]
dotnet_diagnostic.CA1711.severity = none

[src/Graph.Serialization/RuntimeRepresentation/Property.cs]
dotnet_diagnostic.CA1716.severity = none

[src/Graph.Serialization/RuntimeRepresentation/SimpleValue.cs]
dotnet_diagnostic.CA1720.severity = none

[src/Graph.Cypher/ICypherDialect.cs]
dotnet_diagnostic.CA1716.severity = none

[src/Graph.CompatibilityTests/DomainModel.cs]
dotnet_diagnostic.CA1716.severity = none

# Provider schema managers own process-lifetime coordination semaphores. Neither accesses the
# optional wait handle, and their lifetime is bounded by the owning graph store.
[src/Graph.{Age,Neo4j}/Schema/*SchemaManager.cs]
dotnet_diagnostic.CA1001.severity = none

# BenchmarkDotNet invokes GlobalCleanup, which asynchronously disposes each benchmark's graph
# store; implementing IDisposable would create a second, unused cleanup path.
[tests/Graph.Performance.Tests/*Benchmark.cs]
dotnet_diagnostic.CA1001.severity = none

# This xUnit collection type follows the framework's discovery naming convention.
[tests/Graph.CompatibilityTests.Tests/ComplianceLedgerCollection.cs]
dotnet_diagnostic.CA1711.severity = none

# This translation snapshot intentionally pins the string overload's expression shape.
[tests/Graph.Neo4j.Translation.Tests/ExpressionMethodsTranslationTests.cs]
dotnet_diagnostic.CA1847.severity = none

# Underscore-separated scenario names are the established convention for executable tests.
[tests/**.cs]
dotnet_diagnostic.CA1707.severity = none

# The compatibility suite is executable xUnit contract code despite living under src for packing.
[src/Graph.CompatibilityTests/**.cs]
dotnet_diagnostic.CA1707.severity = none

# This test deliberately swaps process culture (restored in a finally) to prove the default-value
# formatter stays culture-invariant. CurrentCulture is thread-local, so the swap does not leak across
# xUnit's parallel test threads; RS1035's ban on it is precisely the behavior under test.
[tests/Graph.Serialization.CodeGen.Tests/DefaultValueFormatterTests.cs]
dotnet_diagnostic.RS1035.severity = none

[*.{csproj,props,targets,xml,yml,yaml,json,md}]
indent_size = 2
