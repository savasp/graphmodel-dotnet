<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <IsPackable>false</IsPackable>
        <RootNamespace>Cvoya.Graph.Model.Serialization.CodeGen.Tests</RootNamespace>
        <AssemblyName>Cvoya.Graph.Model.Serialization.CodeGen.Tests</AssemblyName>

        <!-- Use the new testing platform -->
        <UseMicrosoftTestingPlatform>true</UseMicrosoftTestingPlatform>

        <!-- xunit.v3 generates the entry point used by Microsoft.Testing.Platform. -->
        <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>

        <!-- Enable live output -->
        <TestingPlatformShowTestsFailure>true</TestingPlatformShowTestsFailure>
        <TestingPlatformShowProgress>true</TestingPlatformShowProgress>
        <TestingPlatformCaptureOutput>true</TestingPlatformCaptureOutput>
    </PropertyGroup>

    <!--
        The generator is driven directly via CSharpGeneratorDriver (see GeneratorTestHelpers.cs)
        rather than through Microsoft.CodeAnalysis.CSharp.SourceGenerators.Testing's
        CSharpSourceGeneratorTest: that type's TestState.GeneratedSources requires hardcoding
        the exact expected output per test, which is the opposite of snapshot testing. Verify
        gives snapshot semantics directly against the driver's output.
    -->
    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.6.0" />
        <PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
        <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" Version="18.8.0" />
        <PackageReference Include="Verify.XunitV3" Version="31.20.0" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="Xunit" />
        <Using Include="VerifyXunit" />
    </ItemGroup>

    <!--
        Same workaround as tests/Graph.Model.Neo4j.Translation.Tests: Verify's own MSBuild
        target that writes the `Verify.ProjectDirectory` assembly-metadata attribute does not
        fire reliably in this project's build pipeline. Emit the attributes it needs directly.
    -->
    <ItemGroup>
        <AssemblyMetadata Include="Verify.ProjectDirectory" Value="$(MSBuildProjectDirectory)\" />
        <AssemblyMetadata Include="Verify.ProjectName" Value="$(MSBuildProjectName)" />
        <AssemblyMetadata Include="Verify.TargetFrameworks" Value="$(TargetFramework)" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Graph.Model.Serialization.CodeGen\Graph.Model.Serialization.CodeGen.csproj" />
        <ProjectReference Include="..\..\src\Graph.Model\Graph.Model.csproj" />
        <ProjectReference Include="..\..\src\Graph.Model.Serialization\Graph.Model.Serialization.csproj" />
    </ItemGroup>

</Project>
