<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <IsPackable>false</IsPackable>
        <RootNamespace>Cvoya.Graph.Model.Neo4j.Translation.Tests</RootNamespace>
        <AssemblyName>Cvoya.Graph.Model.Neo4j.Translation.Tests</AssemblyName>

        <!-- Use the new testing platform -->
        <UseMicrosoftTestingPlatform>true</UseMicrosoftTestingPlatform>

        <!-- Enable live output -->
        <TestingPlatformShowTestsFailure>true</TestingPlatformShowTestsFailure>
        <TestingPlatformShowProgress>true</TestingPlatformShowProgress>
        <TestingPlatformCaptureOutput>true</TestingPlatformCaptureOutput>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="xunit.v3.mtp-v2" Version="3.2.2" />
        <PackageReference Include="Verify.XunitV3" Version="31.20.0" />
        <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" Version="18.4.1" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="Xunit" />
        <Using Include="VerifyXunit" />
    </ItemGroup>

    <!--
        Verify's own MSBuild target (WriteVerifyAttributes, from its buildTransitive props/targets)
        does not fire reliably in this project — likely due to interaction with the
        Microsoft.Testing.Platform / xunit.v3.mtp-v2 build pipeline reshaping the standard SDK
        import order. Emit the `Verify.ProjectDirectory` assembly-metadata attribute Verify needs
        for project-relative snapshot directories directly, so tests don't depend on that target.
    -->
    <ItemGroup>
        <AssemblyMetadata Include="Verify.ProjectDirectory" Value="$(MSBuildProjectDirectory)\" />
        <AssemblyMetadata Include="Verify.ProjectName" Value="$(MSBuildProjectName)" />
        <AssemblyMetadata Include="Verify.TargetFrameworks" Value="$(TargetFramework)" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Graph.Model.Neo4j\Graph.Model.Neo4j.csproj" />
        <ProjectReference Include="..\..\src\Graph.Model.Analyzers\Graph.Model.Analyzers.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <ProjectReference Include="..\..\src\Graph.Model.Serialization.CodeGen\Graph.Model.Serialization.CodeGen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" Condition="'$(UseProjectReferences)' == 'true'" />
    </ItemGroup>

</Project>
