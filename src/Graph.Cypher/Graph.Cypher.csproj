<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>library</OutputType>
        <RootNamespace>Cvoya.Graph.Cypher</RootNamespace>
        <AssemblyName>Cvoya.Graph.Cypher</AssemblyName>
    </PropertyGroup>

    <PropertyGroup>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageId>Cvoya.Graph.Cypher</PackageId>
        <Description>A typed Cypher AST and validation framework for GraphModel query generation.</Description>
        <PackageTags>graph;database;cypher;ast;linq</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <Using Include="Cvoya.Graph" />
    </ItemGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
            <_Parameter1>Cvoya.Graph.Cypher.Tests</_Parameter1>
        </AssemblyAttribute>
    </ItemGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
        <ProjectReference Include="../Graph/Graph.csproj" />
    </ItemGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
        <PackageReference Include="Cvoya.Graph" />
    </ItemGroup>

</Project>
