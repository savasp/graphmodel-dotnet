{
  "permissions": {
    "allow": [
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(dotnet clean*)",
      "Bash(dotnet restore*)",
      "Bash(dotnet msbuild*)",
      "Bash(dotnet format*)",
      "Bash(./scripts/run-tests.sh*)",
      "Bash(./scripts/containers/start-neo4j.sh*)",
      "Bash(./scripts/containers/start-age.sh*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh repo view*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)"
    ]
  },
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git -C \"${CLAUDE_PROJECT_DIR:-.}\" rev-parse --show-toplevel)\"/eng/agent-hooks/protect-files.sh"
          }
        ]
      }
    ]
  }
}
